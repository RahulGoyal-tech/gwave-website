---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import FAQ from '@components/sections/misc/FAQ.astro';

import heroImage from '@images/hero-image.avif';
import featureImage from '@images/features-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';
import construction from '@images/construction-image.avif';

import faqs from '@data/faqs.json';
import features from '@data/features.json';
---

<MainLayout>
  <HeroSection
    title=`Precision Electronics Manufacturing, <span class="text-yellow-500 dark:text-yellow-400">Built on Process</span>`
    subTitle="End-to-end PCB assembly and plastic injection job work — from your first prototype to full-scale production, with consistent quality at every stage."
    primaryBtn="Explore Our Services"
    primaryBtnURL="/services"
    secondaryBtn="Contact Us"
    secondaryBtnURL="/contact"
    withReview={false}
    src={heroImage}
    alt="Automated SMT pick-and-place line assembling a printed circuit board"
  />

  <div id="about">
    <FeaturesGeneral
      title="Different by Design: We Standardize Everything"
      subTitle="Most job-work shops rely on tribal knowledge. Gwave runs on defined, repeatable processes — so the quality you see in your prototype is the quality you get in your 10,000th unit. We're building standardized operating procedures for PCB and plastic injection services, moving toward a fully transparent, portal-driven ordering experience."
      src={featureImage}
      alt="Engineer reviewing a standardized assembly process document on the factory floor"
      features={features}
    />
  </div>

  <FeaturesNavs
    title=`Two divisions, one standard of <span class="text-yellow-500 dark:text-yellow-400">quality</span>.`
    tabs={[
      {
        heading: 'Electronics Assembly (PCBA)',
        content:
          'Full turnkey PCB assembly: component and PCB sourcing, automated SMT pick-and-place, and manual assembly. We handle everything from prototype boards to bulk production with consistent, inspection-backed quality.',
        svg: 'chip',
        src: tools,
        alt: 'Automated pick-and-place machine placing components on a PCB',
        first: true,
      },
      {
        heading: 'Plastic Injection Molding',
        content:
          'Precision plastic injection molding services, run on standardized procedures for repeatable parts. Ideal for enclosures and components that pair with your electronics — built to the same process discipline.',
        svg: 'settings',
        src: dashboard,
        alt: 'Plastic injection molding machine producing precision parts',
        second: true,
      },
      {
        heading: 'Testing, Programming & Box Build',
        content:
          'Board testing, IC programming, and complete box build assembly — so you can ship a finished, verified product, not just a populated board.',
        svg: 'badge-check',
        src: construction,
        alt: 'Technician performing functional board testing',
      },
    ]}
  />

  <FeaturesStats
    title="From Prototype to Production"
    subTitle="One standardized process, scaled to whatever your project needs."
    mainStatTitle="100%"
    mainStatSubTitle="of our workflow is process-documented and inspection-backed — from your first board to your ten-thousandth"
    stats={[
      {
        stat: '1 → Bulk',
        description: 'order sizes, from single prototypes to high-volume runs',
      },
      {
        stat: '8',
        description: 'in-house services across electronics and plastics',
      },
      {
        stat: 'SMT',
        description: 'automated pick-and-place for fine-pitch accuracy',
      },
    ]}
  />

  <FAQ title="Frequently<br />asked questions" faqs={faqs} />

  <HeroSectionAlt
    title="Let's Build It Right"
    subTitle="Tell us about your project — prototype or production, electronics or plastics. Our team will help you get from design to delivery with a process you can rely on."
    url="/contact"
  />
</MainLayout>
