---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import imagery (swap these for your own line/PCB/molding photos)
import blueprints from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import beforeAfter from '@images/before-after.avif';
import constructionWorkers from '@images/construction-workers.avif';
import aerialView from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import { SITE } from '@data/constants';

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Gwave Innovation provides end-to-end electronics manufacturing job work — component & PCB sourcing, SMT and manual assembly, board testing, IC programming, and box build — alongside precision plastic injection molding, all run on standardized processes.';
const ogTitle =
  'Electronics Manufacturing & Plastic Injection Services | Gwave Innovation';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${SITE.url}/services`,
    url: `${SITE.url}/services`,
    name: ogTitle,
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  {/* Page intro */}
  <MainSection
    title="Our Services"
    subTitle="Gwave Innovation provides end-to-end electronics manufacturing job work alongside plastic injection molding — all run on standardized, repeatable processes. Whether you need a handful of prototypes or a full production run, you get the same disciplined quality."
    btnExists={true}
    btnTitle="Request a Quote"
    btnURL="/contact"
  />

  {/* Division A — Electronics Manufacturing (PCBA Job Work) */}
  <div id="electronics" class="scroll-mt-24">
    <RightSection
      title="Electronics Manufacturing — PCBA Job Work"
      subTitle="Full turnkey PCB assembly under one roof. We source electronic components against your BOM with attention to authenticity and lead times, and procure bare boards to your exact specifications and quality standards — or assemble using parts you supply. Then our automated SMT pick-and-place lines place fine-pitch components with consistent accuracy at any volume, complemented by skilled manual assembly for through-hole, mixed-technology, and specialized parts."
      single={false}
      imgOne={blueprints}
      imgOneAlt="Gerber files and BOM under review before component sourcing"
      imgTwo={personWorking}
      imgTwoAlt="Engineer preparing a job for the SMT assembly line"
    />
  </div>

  {/* Testing, programming, box build */}
  <div id="testing" class="scroll-mt-24">
    <LeftSection
      title="Testing, Programming & Box Build"
      subTitle="We don't just populate boards — we verify and finish them. Functional and visual inspection confirms every board performs as intended before it ships. In-house IC and microcontroller programming means boards arrive ready to run. And full box build assembly — enclosures, wiring, and final integration — lets you ship a finished, verified product rather than just a populated PCB."
      img={beforeAfter}
      imgAlt="Technician performing functional board testing and final box build"
      btnExists={true}
      btnTitle="Discuss your build"
      btnURL="/contact"
    />
  </div>

  {/* Division B — Plastic Services */}
  <div id="plastic" class="scroll-mt-24">
    <RightSection
      title="Plastic Injection Molding"
      subTitle="Our plastic services division runs precision injection molding on standardized procedures for repeatable, high-quality parts and enclosures — ideal for the housings and components that pair with your electronics. Built to the same process discipline as our PCBA work, so the parts that protect your boards are held to the same standard as the boards themselves."
      single={false}
      imgOne={aerialView}
      imgOneAlt="Plastic injection molding machine in operation"
      imgTwo={usingTools}
      imgTwoAlt="Inspection of a molded plastic enclosure"
    />
  </div>

  {/* Closing standardization statement */}
  <LeftSection
    title="Standardized Today, Self-Serve Tomorrow"
    subTitle="We're standardizing every one of these services into clear operating procedures — and moving toward a transparent, portal-based ordering experience so you always know exactly what to expect, from quote to delivery."
    img={constructionWorkers}
    imgAlt="Team documenting standardized operating procedures on the factory floor"
  />

  {/* Capability stats */}
  <FeaturesStats
    title="Built for Consistency"
    subTitle="Our commitment to process shows up in every job — the same disciplined quality whether it's your first board or your ten-thousandth."
    mainStatTitle="8"
    mainStatSubTitle="in-house services spanning electronics manufacturing and plastic injection"
    stats={[
      {
        stat: '1 → Bulk',
        description: 'prototype through high-volume production',
      },
      {
        stat: 'SMT',
        description: 'automated pick-and-place for fine-pitch accuracy',
      },
      {
        stat: '100%',
        description: 'process-documented, inspection-backed workflow',
      },
    ]}
  />
</MainLayout>
