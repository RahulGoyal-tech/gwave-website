---
// Gwave Innovation — official logo (your uploaded artwork).
// Shows the navy logo on light backgrounds and the white logo on dark — so it
// stays visible in both the header and footer, in light and dark mode.
// Pass `white` to force the white version (e.g. always-dark surfaces).
const { class: className, white = false, ...rest } = Astro.props;
---

{
  white ? (
    <img
      src="/gwave_logo_white.png"
      alt="Gwave Innovation"
      class={className}
      {...rest}
    />
  ) : (
    <>
      <img
        src="/gwave_logo_navy.png"
        alt="Gwave Innovation"
        class={`${className ?? ''} block dark:hidden`}
        {...rest}
      />
      <img
        src="/gwave_logo_white.png"
        alt="Gwave Innovation"
        class={`${className ?? ''} hidden dark:block`}
        {...rest}
      />
    </>
  )
}
