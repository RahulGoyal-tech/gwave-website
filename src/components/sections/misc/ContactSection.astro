---
// Import the necessary dependencies.
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';

// Page copy
const title: string = 'Get in Touch';
const subTitle: string =
  'Have a project, a BOM, or just a question? Send us your requirements and our team will respond with a quote and timeline. We work with everyone from individual makers to established manufacturers.';
const formTitle: string = 'Tell us about your project';
const formSubTitle: string = "We'll get back to you within 1–2 business days.";

// Submit button styling (matches the PrimaryCTA look)
const submitClasses =
  'group inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-orange-400 px-4 py-3 text-sm font-bold text-neutral-50 ring-zinc-500 transition duration-300 outline-hidden hover:bg-orange-500 focus-visible:ring-3 disabled:pointer-events-none disabled:opacity-50 2xl:text-base dark:ring-zinc-200 dark:focus:outline-hidden';
---

{/* Contact Us */}
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        {
          /* Static sites need a form handler. This form is wired for Web3Forms:
             1. Create a free access key at https://web3forms.com using the
                sales@gwaveinnovation.com inbox (that inbox receives submissions).
             2. Replace YOUR_WEB3FORMS_ACCESS_KEY below with that key.
             No backend code required. */
        }
        <form action="https://api.web3forms.com/submit" method="POST">
          <input
            type="hidden"
            name="access_key"
            value="12f7afb6-ad5d-4d70-a1fa-2b857fa41ee1"
          />
          <input
            type="hidden"
            name="subject"
            value="New project enquiry from gwaveinnovation.com"
          />
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="First Name"
                name="first_name"
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Last Name"
                name="last_name"
              />
            </div>
            <EmailContactInput id="hs-email-contacts" />
            <PhoneInput id="hs-phone-number" />
            <div>
              <label
                for="hs-service-contacts"
                class="mb-2 block text-sm font-medium text-neutral-700 dark:text-white"
                >Service needed</label
              >
              <select
                id="hs-service-contacts"
                name="service"
                class="block w-full rounded-lg border-neutral-200 px-4 py-3 text-sm focus:border-yellow-500 focus:ring-yellow-500 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400"
              >
                <option selected value="">Select a service…</option>
                <option value="Component Assembly">Component Assembly</option>
                <option value="Box Build Assembly">Box Build Assembly</option>
                <option value="PCB Sourcing">PCB Sourcing</option>
                <option value="3D Printing">3D Printing</option>
                <option value="Injection Molding">Injection Molding</option>
                <option value="IC Programming & Testing"
                  >IC Programming & Testing</option
                >
                <option value="Other / Not sure">Other / Not sure</option>
              </select>
            </div>
            <TextAreaInput
              id="hs-about-contacts"
              label="Project details (volume, quantity, timeline) — and attach Gerbers / STL / specs by email"
              name="message"
            />
          </div>

          <div class="mt-4 grid">
            <button type="submit" class={submitClasses}>Send Message</button>
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
      </div>

      {/* Direct contact methods */}
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Email us your files"
          content="To request a quote, email your project files to"
          isLinkVisible={true}
          linkTitle="sales@gwaveinnovation.com"
          linkURL="mailto:sales@gwaveinnovation.com"
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Call us"
          content="Speak with our team directly during business hours"
          isLinkVisible={true}
          linkTitle="+91 92117 05237"
          linkURL="tel:+919211705237"
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock heading="Location" content="Delhi, India"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Business hours"
          content="Mon–Fri, 9:30 AM – 6:30 PM"
          ><Icon name="question" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>
