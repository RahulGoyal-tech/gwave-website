---
// Import the necessary dependencies
import FooterSocialLink from '@components/ui/links/FooterSocialLink.astro';
import Icon from '@components/ui/icons/Icon.astro';
import BrandLogo from '@components/BrandLogo.astro';
import enStrings from '@utils/navigation.ts';
import { SITE } from '@data/constants';

const strings = enStrings;

// Tagline shown under the footer logo
const tagline = SITE.tagline;
---

<footer class="w-full bg-neutral-300 dark:bg-neutral-900">
  <div
    class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 lg:pt-20 2xl:max-w-(--breakpoint-2xl)"
  >
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-full lg:col-span-2">
        {/* Brand Logo */}
        <BrandLogo class="h-auto w-44" />
        <p
          class="mt-4 max-w-xs text-sm text-pretty text-neutral-600 dark:text-neutral-400"
        >
          {tagline}. End-to-end PCBA job work and plastic injection molding —
          from prototype to bulk, built on standardized, repeatable processes.
        </p>
      </div>
      {/* An array of links for Company and Services sections */}
      {
        strings.footerLinks.map(section => (
          <div class="col-span-1">
            <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
              {section.section}
            </h3>
            <ul class="mt-3 grid space-y-3">
              {section.links.map(link => (
                <li>
                  <a
                    href={link.url}
                    class="inline-flex gap-x-2 rounded-lg text-neutral-600 ring-zinc-500 outline-hidden transition duration-300 hover:text-neutral-500 focus-visible:ring-3 dark:text-neutral-400 dark:ring-zinc-200 dark:hover:text-neutral-300 dark:focus:outline-hidden"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="col-span-1">
        <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
          Get in touch
        </h3>
        <ul
          class="mt-3 grid space-y-3 text-sm text-neutral-600 dark:text-neutral-400"
        >
          <li>
            <a
              href="mailto:sales@gwaveinnovation.com"
              class="hover:text-neutral-500 dark:hover:text-neutral-300"
              >sales@gwaveinnovation.com</a>
          </li>
          <li>
            <a
              href="tel:+919211705237"
              class="hover:text-neutral-500 dark:hover:text-neutral-300"
              >+91 92117 05237</a>
          </li>
          <li>Delhi, India</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-9 grid gap-y-2 sm:mt-12 sm:flex sm:items-center sm:justify-between sm:gap-y-0"
    >
      <div class="flex items-center justify-between">
        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          © <span id="current-year"></span>
          {SITE.author}. All rights reserved.
        </p>
      </div>

      {/* Social Brands */}
      {
        strings.socialLinks.linkedin && (
          <div>
            <FooterSocialLink url={strings.socialLinks.linkedin}>
              <Icon name="linkedIn" />
            </FooterSocialLink>
          </div>
        )
      }
    </div>

    <script>
      const year = new Date().getFullYear();
      const element = document.getElementById('current-year');
      element!.innerText = year.toString();
    </script>
  </div>
</footer>
